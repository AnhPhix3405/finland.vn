generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attachments {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  url           String
  secure_url    String
  size_bytes    BigInt?
  original_name String?   @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  public_id     String?   @unique(map: "unique_attachments_public_id")
  target_type   String?   @db.VarChar(50)
  target_id     String?   @db.Uuid
  sort_order    Int?      @default(0)

  @@index([target_id, target_type], map: "idx_attachments_target_id_type")
  @@index([target_id, target_type, sort_order], map: "idx_attachments_target_sort")
}

model brokers {
  id                String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  full_name         String      @db.VarChar(255)
  phone             String      @unique(map: "idx_brokers_phone") @db.VarChar(20)
  email             String?     @db.VarChar(255)
  avatar_url        String?
  bio               String?
  is_active         Boolean?    @default(true)
  created_at        DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?   @default(now()) @db.Timestamptz(6)
  province          String?     @db.VarChar(100)
  ward              String?     @db.VarChar(100)
  referrer_phone    String?     @db.VarChar(20)
  password_hash     String?
  address           String?
  is_email_verified Boolean     @default(false)
  bookmarks         bookmarks[]
  listings          listings[]

  @@index([province], map: "idx_brokers_province")
}

model project_tags {
  project_id String   @db.Uuid
  tag_id     String   @db.Uuid
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tags       tags     @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([project_id, tag_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model projects {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  project_code     String?         @unique @db.VarChar(50)
  name             String
  slug             String          @unique @db.VarChar(255)
  content          String?
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?       @default(now()) @db.Timestamptz(6)
  province         String?         @db.VarChar(100)
  ward             String?         @db.VarChar(100)
  price            Decimal         @default(0) @db.Decimal(15, 2)
  status           String?
  area             Decimal?        @db.Decimal(10, 2)
  views_count      Int             @default(0)
  thumbnail_url    String?
  property_type_id String?         @db.Uuid
  latitude         Float?
  longitude        Float?
  project_tags     project_tags[]
  property_types   property_types? @relation(fields: [property_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_projects_property_type")

  @@index([created_at(sort: Desc)], map: "idx_projects_created_at")
  @@index([name], map: "idx_projects_name")
  @@index([status], map: "idx_projects_status")
  @@index([status, created_at(sort: Desc)], map: "idx_projects_status_created_at")
}

model tags {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @unique @db.VarChar(100)
  slug         String         @unique @db.VarChar(120)
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  listing_id   String?        @db.Uuid
  news_tags    news_tags[]
  project_tags project_tags[]
  listings     listings?      @relation(fields: [listing_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tags_listing")
}

model listings {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  broker_id                String                     @db.Uuid
  title                    String
  description              String
  province                 String                     @db.VarChar(100)
  ward                     String                     @db.VarChar(100)
  address                  String?
  area                     Decimal?                   @db.Decimal(10, 2)
  price                    BigInt?
  direction                String?                    @db.VarChar(20)
  status                   String?
  property_type_id         String?                    @db.Uuid
  transaction_type_id      String?                    @db.Uuid
  slug                     String                     @unique(map: "idx_listings_slug_unique")
  contact_name             String?                    @db.VarChar(255)
  contact_phone            String?                    @db.VarChar(50)
  listing_code             String                     @unique @db.VarChar(20)
  floor_count              Int?
  bedroom_count            Int?
  thumbnail_url            String?
  views_count              Int                        @default(0)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  price_per_m2             Decimal?                   @db.Decimal(15, 2)
  price_per_frontage_meter Decimal?                   @db.Decimal(15, 2)
  latitude                 Float?
  longitude                Float?
  bookmarks                bookmarks[]
  listing_feature_hashtags listing_feature_hashtags[]
  brokers                  brokers                    @relation(fields: [broker_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_listings_broker")
  property_types           property_types?            @relation(fields: [property_type_id], references: [id], onUpdate: NoAction, map: "fk_listings_property_type")
  transaction_types        transaction_types?         @relation(fields: [transaction_type_id], references: [id], onUpdate: NoAction, map: "fk_listings_transaction_type")
  tags                     tags[]

  @@index([broker_id], map: "idx_listings_broker_id")
  @@index([price], map: "idx_listings_price")
  @@index([province, ward], map: "idx_listings_province_ward")
  @@index([status], map: "idx_listings_status")
  @@index([property_type_id], map: "idx_listings_property_type_id")
  @@index([transaction_type_id], map: "idx_listings_transaction_type_id")
}

model property_types {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String     @unique @db.VarChar(255)
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at DateTime?  @default(now()) @db.Timestamptz(6)
  hashtag    String     @unique @db.VarChar(255)
  listings   listings[]
  projects   projects[]
}

model transaction_types {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String     @unique @db.VarChar(255)
  hashtag    String     @unique @db.VarChar(255)
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at DateTime?  @default(now()) @db.Timestamptz(6)
  listings   listings[]
}

model admins {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email         String    @unique
  name          String
  password_hash String
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model bookmarks {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  listing_id String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  broker_id  String    @db.Uuid
  brokers    brokers   @relation(fields: [broker_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bookmarks_brokers")
  listings   listings  @relation(fields: [listing_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_listing")

  @@unique([broker_id, listing_id], map: "unique_broker_listing")
  @@index([broker_id], map: "idx_bookmarks_broker_id")
  @@index([listing_id], map: "idx_bookmarks_listing_id")
}

model news {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title         String      @db.VarChar(255)
  slug          String      @unique @db.VarChar(255)
  content       String
  description   String?
  thumbnail_url String?
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?   @default(now()) @db.Timestamptz(6)
  news_tags     news_tags[]
}

model news_tags {
  news_id String @db.Uuid
  tag_id  String @db.Uuid
  news    news   @relation(fields: [news_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_news_tags_news")
  tags    tags   @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_news_tags_tags")

  @@id([news_id, tag_id])
  @@index([tag_id], map: "idx_news_tags_tag_id")
}

model feature_hashtags {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                     String                     @unique @db.VarChar(255)
  hashtag                  String                     @unique @db.VarChar(255)
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  listing_feature_hashtags listing_feature_hashtags[]
}

model listing_feature_hashtags {
  listing_id         String           @db.Uuid
  feature_hashtag_id String           @db.Uuid
  feature_hashtags   feature_hashtags @relation(fields: [feature_hashtag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_listing_feature_hashtag")
  listings           listings         @relation(fields: [listing_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_listing_feature_listing")

  @@id([listing_id, feature_hashtag_id])
  @@index([feature_hashtag_id], map: "idx_listing_feature_hashtags_feature_hashtag_id")
}

enum post_status {
  published
  draft
}

enum project_status {
  s_p_m__b_n   @map("sắp mở bán")
  ang_m__b_n   @map("đang mở bán")
  h_ng_th__c_p @map("hàng thứ cấp")
}
